{
  "_meta": {
    "version": 1,
    "description": "Domain-specific scriptlet rules for anti-adblock bypass",
    "updated": "2026-03-12"
  },
  "generic": [
    { "scriptlet": "set-constant", "args": ["canRunAds", "true"] },
    { "scriptlet": "set-constant", "args": ["adBlockDetected", "false"] },
    { "scriptlet": "set-constant", "args": ["isAdBlockActive", "false"] },
    { "scriptlet": "abort-on-property-read", "args": ["FuckAdBlock"] },
    { "scriptlet": "abort-on-property-read", "args": ["BlockAdBlock"] },
    { "scriptlet": "abort-on-property-read", "args": ["detectAdBlock"] },
    { "scriptlet": "set-constant", "args": ["adblockDetector", "noopFunc"] },
    { "scriptlet": "abort-on-property-read", "args": ["adBlockDetected"] }
  ],
  "forbes.com": [
    { "scriptlet": "set-constant", "args": ["fbs_settings.canRunAds", "true"] },
    { "scriptlet": "abort-on-property-read", "args": ["AdBlocker"] },
